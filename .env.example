# =============================================
# AuthForge — Environment Variables
# =============================================
# Copy this file to .env and fill in the values

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/authforge

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets (Must be at least 32 characters long)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production

# Frontend URL (for email links and OAuth callbacks)
FRONTEND_URL=http://localhost:3000

# ---- OAuth (Optional) ----

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/oauth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5000/auth/oauth/github/callback

# ---- Email SMTP (Optional — falls back to console logging in dev) ----

# Use Ethereal (https://ethereal.email) or Mailtrap for development
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=AuthForge <noreply@authforge.dev>
